/dts-v1/;
#include "qcom-msm8974-microsoft-common.dtsi"
/ {
	model = "Nokia Lumia 1520";
	compatible = "microsoft,rm940", "qcom,msm8974";

	aliases {
		display0 = &framebuffer0;
	};

	chosen {
		#address-cells = <1>;
		#size-cells = <1>;
		ranges;
		stdout-path = "display0";

		framebuffer0: framebuffer@400000 {
			compatible = "simple-framebuffer";
			reg = <0x00400000 0x00800000>;
			width = <1080>;
			height = <1920>;
			stride = <(1080 * 4)>;
			format = "a8r8g8b8";
			clocks = <&mmcc MDSS_AHB_CLK>,
				 <&mmcc MDSS_AXI_CLK>,
				 <&mmcc MDSS_BYTE0_CLK>,
				 <&mmcc MDSS_MDP_CLK>,
				 <&mmcc MDSS_PCLK0_CLK>,
				 <&mmcc MDSS_VSYNC_CLK>;
			power-domains = <&mmcc MDSS_GDSC>;
		};
	};
};

/* microSD slot (1520-specific; the 930 has none). Card-detect GPIO still
 * unknown -> broken-cd polls for the card. Supplies TODO (WP firmware
 * leaves the SD rail up; clk/pd_ignore_unused keeps it that way). */
&sdhc_2 {
	status = "okay";
	broken-cd;
};

/* Stage-2 probing: enable every BLSP I2C bus that has default pinctrl in the
 * SoC dtsi, so the touch controller (and sensors) can be located live with
 * i2cdetect. Trim to the buses actually used once mapped. */
&blsp1_i2c1 { status = "okay"; };
&blsp1_i2c2 { status = "okay"; };
&blsp1_i2c3 { status = "okay"; };
&blsp1_i2c6 { status = "okay"; };
&blsp2_i2c2 { status = "okay"; };
&blsp2_i2c5 { status = "okay"; };
&blsp2_i2c6 { status = "okay"; };

/* Touchscreen -- wiring extracted from the stock WP ACPI DSDT (PLAT
 * partition, Device TSC1 "NOKIA_TOUCH"):
 *   bus \_SB.I2C2 = 0xF9924000 = blsp1_i2c2, addr 0x4B, 400 kHz
 *   GpioInt: tlmm 61, edge active-low, pull-up
 *   GpioIo:  tlmm 60 (enable/reset -- hogged high below)
 * Controller family guess: Synaptics RMI4 (Lumia-era standard at 0x4b);
 * if probe rejects, switch compatible to atmel,maxtouch. */
&blsp1_i2c2 {
	clock-frequency = <400000>;

	touchscreen@4b {
		compatible = "syna,rmi4-i2c";
		reg = <0x4b>;
		vdd-supply = <&pm8941_l22>;
		vio-supply = <&pm8941_l6>;
		interrupt-parent = <&tlmm>;
		interrupts = <61 2>;	/* IRQ_TYPE_EDGE_FALLING */

		#address-cells = <1>;
		#size-cells = <0>;

		rmi4-f01@1 {
			reg = <0x1>;
			syna,nosleep-mode = <1>;
		};

		rmi4-f11@11 {
			reg = <0x11>;
			syna,sensor-type = <1>;
		};

		rmi4-f12@12 {
			reg = <0x12>;
			syna,sensor-type = <1>;
		};
	};
};

&tlmm {
	touch-enable-hog {
		gpio-hog;
		gpios = <60 0>;		/* GPIO_ACTIVE_HIGH */
		output-high;
		line-name = "touch-enable";
	};
};

/* Buttons -- wiring from the stock ACPI DSDT (Device BTN0, PNP0C40 array),
 * independently matching the Lumia 930 out-of-tree port:
 *   volume-up = pm8941 gpio5, camera focus = gpio4, shutter = gpio3
 *   (ACPI: edge/both, pull-up => active-low), volume-down = PON RESIN. */
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/pinctrl/qcom,pmic-gpio.h>

/ {
	gpio-keys {
		compatible = "gpio-keys";
		pinctrl-names = "default";
		pinctrl-0 = <&gpio_keys_pin_a>;

		key-volume-up {
			label = "Volume Up";
			gpios = <&pm8941_gpios 5 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_VOLUMEUP>;
			debounce-interval = <15>;
		};

		key-camera-focus {
			label = "Camera Focus";
			gpios = <&pm8941_gpios 4 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_CAMERA_FOCUS>;
			debounce-interval = <15>;
		};

		key-camera-snapshot {
			label = "Camera Snapshot";
			gpios = <&pm8941_gpios 3 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_CAMERA>;
			debounce-interval = <15>;
		};
	};
};

&pm8941_gpios {
	gpio_keys_pin_a: gpio-keys-active-state {
		pins = "gpio3", "gpio4", "gpio5";
		function = "normal";
		bias-pull-up;
		power-source = <PM8941_GPIO_S3>;
	};
};

&pm8941_resin {
	status = "okay";
	linux,code = <KEY_VOLUMEDOWN>;
};

/*
 * WCNSS/Pronto is intentionally disabled on RM-940.
 *
 * The firmware loads and PAS auth-and-reset returns success, but the
 * remote processor never signals ready and qcom-wcnss-pil times out.
 * Allowing wcn36xx to probe after the failed startup has caused full
 * device resets.
 *
 * Keep disabled until the PAS/ready path is further instrumented or
 * an alternative remoteproc startup method is implemented.
 * (Experimental enabled config: branch research/pronto-pas-timeout.)
 */
&pronto {
	status = "disabled";
};

/*
 * PM8941 SMBB charger.
 *
 * Enabling this gives full charge telemetry (battery present/health, charge
 * status, USB-power detection) and works -- BUT on this device it also hands
 * the charger control of the USB "usbin"/VBUS detection, which shares the
 * physical connector with our USB network/SSH gadget. That perturbs the USB
 * HS PHY, which cannot re-power (the same "phy poweron failed -22" limit that
 * blocks suspend), and the gadget dies until a cold power cycle. So SMBB is
 * left disabled by default -- we are a USB-accessed device.
 *
 * Battery VOLTAGE and TEMPERATURE telemetry do NOT need SMBB: the PM8941 VADC
 * (already enabled) exposes VBAT_SNS and the battery thermistor. See
 * tools/batstat.py for a self-calibrating readout.
 *
 * TODO: a telemetry-only SMBB config that leaves usbin/OTG-VBUS to the USB
 * stack (drop otg-vbus / usbin wiring) may give charge status without the PHY
 * fight. Charge limits when re-enabled (conservative, from mainline FP2 /
 * same PM8941): usb+fast 1.5A, safe-voltage 4.35V, high-threshold 4.30V.
 */
&smbb {
	status = "disabled";
};

/*
 * Backlight -- PM8941 WLED (WLED3, 3 strings). This drives the 1520's IPS
 * LCD backlight: brightness 0 = backlight OFF (verified: physical panel
 * tracks brightness, 30 off/on cycles clean, ~24mV VBAT rise when off).
 * Creates /sys/class/backlight/backlight (max 4095). The "IRQ ovp not found"
 * dmesg warning is benign (over-voltage-protection interrupt is optional and
 * not wired in the base pm8941.dtsi node).
 * This is the only working display power control on the simpledrm setup --
 * there is no DSI panel driver, so DRM DPMS does not power the panel.
 */
&pm8941_wled {
	status = "okay";
	default-brightness = <2048>;
};
